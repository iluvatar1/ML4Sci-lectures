{
  "LiteBuildConfig": {
    "output_dir": "lite-build",
    "contents": ["lectures", "requirements.txt"],
    "extra_ignore_contents": [
      "\\.devcontainer",
      "\\.venv",
      "\\.git",
      "\\.github"
    ],
    "ignore_sys_prefix": ["@jupyterlab/git"]
  },
  "LiteServerConfig": {
    "base_url": "/ML4Sci-lectures/lab/"
  },
  "jupyter-config-data": {
    "disabledExtensions": ["@jupyterlab/git:plugin", "@jupyterlab/git", "@jupyterlab/git:git", "@jupyterlab/git:settings"]
  }
}
